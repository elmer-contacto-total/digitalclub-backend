# Variables de entorno para infinance.innovag.com.pe
# Plantilla — los secretos están vacíos. Copiar a /etc/holape/holape.env
# en la VM (chmod 640, owner root:holape) y reemplazar cada REPLACE_AT_BOOTSTRAP
# por el valor real (ver al final del archivo o pedir las credenciales).

SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8443

# --- Database (RDS de infinance) ---
DB_HOST=digital-club.clbzi5ldkemb.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=digital_club_staging
DB_USERNAME=postgres
DB_PASSWORD=REPLACE_AT_BOOTSTRAP

# --- Flyway ---
# Activar después de borrar las migraciones existentes y dropear flyway_schema_history
# (ver deploy/README.md, sección "Reset de Flyway")
FLYWAY_ENABLED=true

# --- Redis (local en la VM) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT (generar con: openssl rand -base64 48) ---
JWT_SECRET=REPLACE_AT_BOOTSTRAP

# --- AWS S3 ---
AWS_REGION=us-east-1
AWS_S3_BUCKET=infinance-prod
AWS_S3_LEGACY_BUCKET=digitalgroup-prod
AWS_ACCESS_KEY_ID=REPLACE_AT_BOOTSTRAP
AWS_SECRET_ACCESS_KEY=REPLACE_AT_BOOTSTRAP

# --- Mail (SES) ---
MAIL_HOST=email-smtp.us-east-1.amazonaws.com
MAIL_PORT=587
MAIL_USERNAME=REPLACE_AT_BOOTSTRAP
MAIL_PASSWORD=REPLACE_AT_BOOTSTRAP
APP_MAIL_FROM=noreplay@infinance.innovag.com.pe
APP_MAIL_FROM_NAME=Infinance Cobranza

# --- CORS ---
ALLOWED_ORIGINS=https://infinance.innovag.com.pe

# --- SMS (Digital Club / Intico) ---
DIGITAL_CLUB_SMS_USER=Digclub_ws
DIGITAL_CLUB_SMS_PASSWORD=REPLACE_AT_BOOTSTRAP
APP_SMS_NAME=InFinance
